{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "bun"]
  },
  "include": [
    "cli/**/*.ts",
    "config/**/*.ts",
    "pipelines/**/*.ts",
    "schemas/**/*.ts",
    "types/**/*.ts",
    "llm/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "tests"]
}
